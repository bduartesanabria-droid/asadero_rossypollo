# ====================================
# Configuración de Entorno - EJEMPLO
# ====================================
# Copia este archivo a .env y reemplaza los valores con los tuyos

# Entorno (development, production)
FLASK_ENV=development

# Clave Secreta (cambiar en producción)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Base de Datos
DATABASE_URL=sqlite:///asadero.db

# Configuración de Flask
FLASK_APP=run.py
DEBUG=True

# Puerto de la aplicación
PORT=5000

# Host de la aplicación
HOST=0.0.0.0
