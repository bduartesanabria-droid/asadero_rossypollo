# ====================================
# Configuración de Entorno - EJEMPLO
# ====================================
# Copia este archivo a .env y reemplaza los valores con los tuyos

# Entorno (development, production)
FLASK_ENV=production

# Clave secreta (cambiar en producción)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Base de datos (para Docker se usa MySQL)
DATABASE_URL=mysql+pymysql://asadero:asadero_pass@db:3306/asadero

# Configuración de la base de datos MySQL para Docker
MYSQL_DATABASE=asadero
MYSQL_USER=asadero
MYSQL_PASSWORD=asadero_pass
MYSQL_ROOT_PASSWORD=root_pass

# Configuración de Flask
FLASK_APP=run.py
DEBUG=False

# Usuario administrador inicial (opcional)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_password

# Puerto de la aplicación
PORT=5000

# Host de la aplicación
HOST=0.0.0.0
