# ====================================
# Configuración de Entorno - EJEMPLO
# ====================================
# Copia este archivo a .env y reemplaza los valores con los tuyos

# Clave secreta (cambiar en producción)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Base de datos SQLite
DATABASE_URL=sqlite:///asadero.db

# Configuración de Flask
FLASK_APP=run.py

# Usuario administrador inicial (opcional)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_password

# Puerto de la aplicación
PORT=5000

# Host de la aplicación
HOST=0.0.0.0

# Configuración de correo electrónico (para enviar bonos a ganadores)
# Usa una cuenta de Gmail con "Contraseña de aplicación" (no tu contraseña normal)
# Actívala en: Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_DEFAULT_SENDER=Asadero Rossypollo <tucorreo@gmail.com>

# Opciones para MySQL (cuando uses Docker Compose)
# Descomenta y ajusta si quieres usar MySQL en lugar de SQLite
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_DATABASE=asadero
# MYSQL_USER=asaderouser
# MYSQL_PASSWORD=password
# DATABASE_URL=mysql+pymysql://asaderouser:password@db:3306/asadero
